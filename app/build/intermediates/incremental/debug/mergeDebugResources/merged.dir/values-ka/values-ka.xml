    <string name="battery_optimization_continue">გაგრძელება</string>
    <string name="battery_optimization_detected">ბატარეის ოპტიმიზაცია აღმოჩნდა</string>
    <string name="battery_optimization_detected_title">ბატარეის ოპტიმიზაცია აღმოჩნდა</string>
    <string name="battery_optimization_disable_button">ბატარეის ოპტიმიზაციის გამორთვა</string>
    <string name="battery_optimization_disabled">ბატარეის ოპტიმიზაცია გამორთულია</string>
    <string name="battery_optimization_disabled_title">ბატარეის ოპტიმიზაცია გამორთულია</string>
    <string name="battery_optimization_enabled_title">ბატარეის ოპტიმიზაცია ჩართულია</string>
    <string name="battery_optimization_explanation">MeshWave მუშაობს ფონში, რათა ახლომდებარე მოწყობილობებთან mesh-კავშირები შეინარჩუნოს. ბატარეის ოპტიმიზაციამ შეიძლება დააწყვეტინოს ეს კავშირები, რის გამოც შეტყობინებები დაგვიანდეს ან დაიკარგოს.\n\nბატარეის ოპტიმიზაციის გამორთვა უზრუნველყოფს სანდო peer-to-peer კომუნიკაციას.</string>
    <string name="battery_optimization_explanation_short">mesh კავშირების შესანარჩუნებლად MeshWave უნდა იმუშავოს ფონში. ბატარეის ოპტიმიზაციამ შეიძლება დაარღვიოს ეს კავშირები.</string>
    <string name="battery_optimization_not_required">ბატარეის ოპტიმიზაცია არ არის საჭირო</string>
    <string name="battery_optimization_not_supported_explanation">თქვენს მოწყობილობას ბატარეის ოპტიმიზაცია არ სჭირდება. MeshWave ჩვეულებრივ იმუშავებს.</string>
    <string name="battery_optimization_not_supported_message">თქვენს მოწყობილობას ბატარეის ოპტიმიზაცია არ სჭირდება. MeshWave ჩვეულებრივ იმუშავებს.</string>
    <string name="battery_optimization_note">შენიშვნა: შეგიძლიათ შეცვალოთ მოგვიანებით Android-ის პარამეტრებში > აპები > MeshWave > ბატარეა.</string>
    <string name="battery_optimization_skip">ახლა გამოტოვება</string>
    <string name="battery_optimization_success_message">MeshWave შეძლებს სანდოდ იმუშაოს ფონში</string>
    <string name="battery_optimization_why_disable">რატომ უნდა გამოირთოს ბატარეის ოპტიმიზაცია?</string>
    <string name="benefits_of_disabling">გამორთვის სარგებელი</string>
    <string name="bluetooth_needs_bullets">• ახლომდებარე მომხმარებლების აღმოჩენა\n• mesh ქსელის კავშირების შექმნა\n• შეტყობინებების გაგზავნა/მიღება\n• მუშაობა ინტერნეტის ან სერვერების გარეშე</string>
    <string name="bluetooth_needs_for">MeshWave-ს სჭირდება Bluetooth შემდეგისთვის:</string>
    <string name="bluetooth_not_supported">Bluetooth არ მხარდაჭერილია</string>
    <string name="bluetooth_required">Bluetooth საჭიროა</string>
    <string name="bluetooth_unsupported_explanation">ამ მოწყობილობას არ უჭერს მხარს Bluetooth Low Energy (BLE), რომელიც საჭიროა MeshWave-ისთვის.\n\nBLE საჭიროა mesh ქსელების შესაქმნელად და ახლომდებარე მოწყობილობებთან ინტერნეტის გარეშე კომუნიკაციისთვის.</string>
