    <string name="battery_optimization_benefits">• Zuverlässige Zustellung von Nachrichten\n• Aufrechterhaltung der Mesh‑Verbindung\n• Hintergrundweiterleitung von Nachrichten\n• Verhindert Verbindungsabbrüche</string>
    <string name="battery_optimization_check_again">Erneut prüfen</string>
    <string name="battery_optimization_checking">Akku‑Optimierung wird geprüft</string>
    <string name="battery_optimization_continue">Fortfahren</string>
    <string name="battery_optimization_detected">Akku‑Optimierung erkannt</string>
