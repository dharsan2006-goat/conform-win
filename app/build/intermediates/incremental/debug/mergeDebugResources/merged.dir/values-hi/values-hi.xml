    <string name="battery_optimization_detected_title">बैटरी अनुकूलन मिला</string>
    <string name="battery_optimization_disable_button">बैटरी अनुकूलन बंद करें</string>
    <string name="battery_optimization_disabled">बैटरी अनुकूलन बंद है</string>
    <string name="battery_optimization_disabled_title">बैटरी अनुकूलन बंद</string>
    <string name="battery_optimization_enabled_title">बैटरी अनुकूलन चालू है</string>
    <string name="battery_optimization_explanation">MeshWave पृष्ठभूमि में चलती है ताकि पास के उपकरणों के साथ मेष कनेक्शन बनाए रखे। बैटरी अनुकूलन इन कनेक्शनों को बाधित कर सकता है, जिससे संदेश देर से पहुँचें या खो जाएँ।\n\nबैटरी अनुकूलन बंद करने से विश्वसनीय पीयर‑टू‑पीयर संचार सुनिश्चित होता है।</string>
    <string name="battery_optimization_explanation_short">मेष कनेक्शन बनाए रखने के लिए MeshWave को पृष्ठभूमि में चलना होता है। बैटरी अनुकूलन इन कनेक्शनों को बाधित कर सकता है।</string>
    <string name="battery_optimization_not_required">बैटरी अनुकूलन आवश्यक नहीं</string>
    <string name="battery_optimization_not_supported_explanation">आपके डिवाइस को बैटरी अनुकूलन सेटिंग्स की आवश्यकता नहीं है। MeshWave सामान्य रूप से चलेगी।</string>
    <string name="battery_optimization_not_supported_message">आपके डिवाइस को बैटरी अनुकूलन सेटिंग्स की आवश्यकता नहीं है। MeshWave सामान्य रूप से चलेगी।</string>
    <string name="battery_optimization_note">नोट: आप इसे बाद में Android सेटिंग्स > ऐप्स > MeshWave > बैटरी में बदल सकते हैं।</string>
    <string name="battery_optimization_skip">अभी छोड़ें</string>
    <string name="battery_optimization_success_message">MeshWave पृष्ठभूमि में विश्वसनीय रूप से चल सकती है</string>
