    <string name="battery_optimization_enabled_title">Batterijoptimalisatie ingeschakeld</string>
    <string name="battery_optimization_explanation">MeshWave draait op de achtergrond om meshnetwerkverbindingen met apparaten in de buurt te onderhouden. Batterijoptimalisatie kan deze verbindingen onderbreken, waardoor berichten vertraagd of gemist worden.\n\nHet uitschakelen van batterijoptimalisatie zorgt voor betrouwbare peer-to-peer communicatie.</string>
    <string name="battery_optimization_explanation_short">MeshWave moet op de achtergrond draaien om meshverbindingen te onderhouden. batterijoptimalisatie kan deze verbindingen onderbreken.</string>
    <string name="battery_optimization_not_required">Batterijoptimalisatie niet vereist</string>
    <string name="battery_optimization_not_supported_explanation">Uw apparaat vereist geen batterijoptimalisatie-instellingen. MeshWave zal normaal draaien.</string>
    <string name="battery_optimization_not_supported_message">Uw apparaat vereist geen batterijoptimalisatie-instellingen. MeshWave zal normaal draaien.</string>
    <string name="battery_optimization_note">Opmerking: U kunt deze instelling later wijzigen in Android-instellingen > Apps > MeshWave > Batterij</string>
    <string name="battery_optimization_skip">Nu overslaan</string>
    <string name="battery_optimization_success_message">MeshWave kan betrouwbaar op de achtergrond draaien</string>
    <string name="battery_optimization_why_disable">Waarom batterijoptimalisatie uitschakelen?</string>
    <string name="benefits_of_disabling">Voordelen van uitschakelen</string>
    <string name="bluetooth_needs_bullets">• Gebruikers in de buurt te ontdekken\n• Meshnetwerkverbindingen te maken\n• Berichten te verzenden en ontvangen\n• Te werken zonder internet of servers</string>
    <string name="bluetooth_needs_for">MeshWave heeft Bluetooth nodig om:</string>
    <string name="bluetooth_not_supported">Bluetooth niet ondersteund</string>
    <string name="bluetooth_required">Bluetooth vereist</string>
    <string name="bluetooth_unsupported_explanation">Dit apparaat ondersteunt geen Bluetooth Low Energy (BLE), wat vereist is om MeshWave te laten functioneren.\n\nMeshWave heeft BLE nodig om meshnetwerken te maken en te communiceren met apparaten in de buurt zonder internet.</string>
